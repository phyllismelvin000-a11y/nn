BOT_TOKEN=123456:ABC-DEF...
ADMIN_CHAT_ID=123456789
WAVE_MERCHANT_ID=
WAVE_PHONE=221771234567

# En production (Railway, Render, Vercel…) : obligatoire. Une des deux options :
# Option A — JSON en clair (une seule ligne, sans retours à la ligne) :
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...", ...}
# Option B — Base64 (recommandé sur Railway). Générer avec : node scripts/firebase-env-base64.js puis coller la sortie dans FIREBASE_SERVICE_ACCOUNT_BASE64
# FIREBASE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# Optionnel : URLs des images des catégories (Netflix / Onoff) pour /catalogue
# Uploadez vos images (ex. Netflix-Switch.webp, images.jpg) sur un hébergeur et collez les liens ici
# NETFLIX_CAT_IMAGE_URL=https://...
# ONOFF_CAT_IMAGE_URL=https://...

# Backoffice web (gestion produits + commandes)
# Si BACKOFFICE_PASSWORD est défini, le backoffice est accessible à http://localhost:3000/admin
BACKOFFICE_PASSWORD=
# Port du backoffice (ignoré si l'hébergeur définit PORT)
BACKOFFICE_PORT=3000
# Optionnel : URL du backoffice pour le bouton dans le menu admin du bot
# En production : servir le backoffice en HTTPS et mettre l'URL ici (ex: https://ton-site.com)
# pour que le bouton "Backoffice" du bot fonctionne partout (Telegram n'accepte pas http://localhost)
# BACKOFFICE_URL=https://...
# Optionnel : secret de session (défaut = BACKOFFICE_PASSWORD)
# BACKOFFICE_SECRET=

# --- Vérification Wave Business (bouton "Vérifier Wave" dans le backoffice) ---
# Optionnel. Permet de vérifier qu'un paiement apparaît sur ton compte Wave Business sans ouvrir le navigateur.
# 1) Lance une fois : node scripts/wave-login.js (avec WAVE_BUSINESS_MOBILE et WAVE_BUSINESS_PIN ou en les saisissant)
# 2) Copie les lignes affichées dans .env
# WAVE_BUSINESS_TOKEN=
# WAVE_BUSINESS_WALLET_ID=

# --- Bot WhatsApp (npm run start:whatsapp) ---
# Même Firestore/Wave que le bot Telegram. Connexion par QR (whatsapp-web.js).
# Optionnel : numéro admin WhatsApp (indicatif + numéro, ex. 225071234567) pour voir le stock via WhatsApp
# ADMIN_WHATSAPP_PHONE=225071234567
# IA conversationnelle : réponses en langage naturel (ex. "Je veux Onoff Premium 1 mois"). Modèle par défaut : mistral-small-latest
# MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-latest
